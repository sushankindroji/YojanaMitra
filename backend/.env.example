# Full PostgreSQL connection string. Create local DB first, then set your DB password.
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/yojanamitra

# Database driver in use. Keep as postgresql unless backend code is changed.
DATABASE_TYPE=postgresql

# JWT signing secret. Generate with: openssl rand -hex 32
SECRET_KEY=generate-with-openssl-rand-hex-32

# JWT algorithm for token signing.
ALGORITHM=HS256

# Access token validity in minutes.
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Refresh token validity in days.
REFRESH_TOKEN_EXPIRE_DAYS=7

# Gemini API key from Google AI Studio: https://aistudio.google.com
GEMINI_API_KEY=your-gemini-api-key-from-aistudio-google-com

# Encryption key for sensitive data. Generate with: openssl rand -hex 32
ENCRYPTION_KEY=generate-with-openssl-rand-hex-32

# SMTP server host. Gmail default shown.
SMTP_HOST=smtp.gmail.com

# SMTP server port. Gmail TLS port is 587.
SMTP_PORT=587

# Sender email account used for transactional emails.
SMTP_USER=your-gmail-address@gmail.com

# Gmail app password (16 characters). Create from Google Account security settings.
SMTP_PASSWORD=your-16-char-gmail-app-password

# From address shown in outgoing emails.
FROM_EMAIL=noreply@yojanamitra.in

# Directory for encrypted uploads (relative to backend root).
UPLOAD_DIR=uploads

# Runtime environment: development or production.
ENVIRONMENT=development

# Allowed frontend origins, comma-separated if multiple.
ALLOWED_ORIGINS=http://localhost:5173

# Optional Tesseract binary path override. Leave as default unless custom install path is used.
TESSERACT_PATH=C:\\Program Files\\Tesseract-OCR\\tesseract.exe

# OCR language packs preference (requires matching tesseract language data files).
TESSERACT_LANGS=eng+hin

# OCR average confidence threshold below which UI should request manual review.
OCR_CONFIDENCE_THRESHOLD=0.6

# Auto-apply Alembic migrations on backend startup.
AUTO_RUN_MIGRATIONS=true

# Maximum upload size in MB.
MAX_UPLOAD_SIZE_MB=10

# Optional Redis URL (leave blank when cache is disabled).
REDIS_URL=
