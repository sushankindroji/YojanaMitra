# Database
DATABASE_URL=postgresql://postgres:root@localhost:5432/yojanamitra
DATABASE_TYPE=postgresql
DB_HOST=localhost
DB_PORT=5432
DB_USER=yojanamitra
DB_PASSWORD=secure_password_here
DB_NAME=yojanamitra_db

# Redis Cache
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=false
CACHE_TTL=3600

# JWT
SECRET_KEY=your_64_character_random_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI
GEMINI_API_KEY=your_gemini_api_key_from_aistudio

# Google OAuth
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# Encryption
ENCRYPTION_KEY=your_32_byte_base64_encoded_key

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password
FROM_EMAIL=noreply@yojanamitra.in

# File Storage
UPLOAD_DIR=uploads

# Environment
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:5173

# OCR
TESSERACT_PATH=C:\\Program Files\\Tesseract-OCR\\tesseract.exe
